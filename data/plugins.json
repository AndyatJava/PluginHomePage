[
  {
    "id": "com.modelflow.browser",
    "name": "浏览器自动化",
    "version": "1.1.0",
    "author": "ModelFlow",
    "type": "official",
    "category": "browser",
    "description": "基于 Playwright 驱动浏览器完成网页导航、点击、填表、截图等操作，让模型能够访问实时网页上下文。",
    "tags": ["browser", "playwright", "automation", "web"],
    "repo": "https://github.com/ModelFlow-App/plugins/tree/main/browser",
    "downloadUrl": "https://github.com/ModelFlow-App/plugins/releases/download/browser-v1.1.0/com.modelflow.browser.zip",
    "permissions": [
      { "type": "browser" },
      { "type": "network", "allowedHosts": ["*"] },
      { "type": "window" }
    ],
    "tools": [
      { "name": "browser_navigate", "description": "打开或跳转到指定 URL" },
      { "name": "browser_click", "description": "点击页面元素" },
      { "name": "browser_fill", "description": "填写输入框" },
      { "name": "browser_screenshot", "description": "截取页面截图" },
      { "name": "browser_get_content", "description": "获取页面文本或 HTML" },
      { "name": "browser_execute_js", "description": "执行 JavaScript" }
    ],
    "settings": [
      { "key": "headless", "label": "无头模式", "type": "boolean", "description": "是否在无头模式下运行浏览器", "default": true },
      { "key": "defaultTimeout", "label": "默认超时（毫秒）", "type": "number", "default": 30000 }
    ],
    "windows": [
      { "windowId": "browser-main", "title": "浏览器控制面板", "defaultMode": "floating", "defaultWidth": 900, "defaultHeight": 700 }
    ]
  },
  {
    "id": "com.modelflow.fileops",
    "name": "文件操作",
    "version": "1.0.0",
    "author": "ModelFlow",
    "type": "official",
    "category": "dev-tools",
    "description": "为模型提供安全的本地文件读写、目录列举、文件搜索能力，支持白名单路径控制。",
    "tags": ["file", "filesystem", "tools"],
    "repo": "https://github.com/ModelFlow-App/plugins/tree/main/fileops",
    "downloadUrl": "https://github.com/ModelFlow-App/plugins/releases/download/fileops-v1.0.0/com.modelflow.fileops.zip",
    "permissions": [
      { "type": "filesystem", "allowedPaths": ["$WORKSPACE"] },
      { "type": "network" }
    ],
    "tools": [
      { "name": "file_read", "description": "读取文本文件内容" },
      { "name": "file_write", "description": "写入文本文件" },
      { "name": "dir_list", "description": "列出目录内容" },
      { "name": "file_search", "description": "按名称搜索文件" }
    ],
    "settings": [
      { "key": "allowedPaths", "label": "允许访问的路径", "type": "string", "description": "逗号分隔的绝对路径白名单", "default": "$WORKSPACE" }
    ]
  },
  {
    "id": "com.modelflow.search",
    "name": "联网搜索",
    "version": "1.0.2",
    "author": "ModelFlow",
    "type": "official",
    "category": "productivity",
    "description": "为模型提供 Brave / Tavily 搜索能力，实时获取互联网信息并注入对话上下文。",
    "tags": ["search", "web", "productivity"],
    "repo": "https://github.com/ModelFlow-App/plugins/tree/main/search",
    "downloadUrl": "https://github.com/ModelFlow-App/plugins/releases/download/search-v1.0.2/com.modelflow.search.zip",
    "permissions": [
      { "type": "network", "allowedHosts": ["api.search.brave.com", "api.tavily.com"] }
    ],
    "tools": [
      { "name": "search_brave", "description": "使用 Brave Search 搜索网页" },
      { "name": "search_tavily", "description": "使用 Tavily Search 搜索网页" }
    ],
    "settings": [
      { "key": "braveApiKey", "label": "Brave API Key", "type": "password", "required": true },
      { "key": "tavilyApiKey", "label": "Tavily API Key", "type": "password", "required": false }
    ]
  },
  {
    "id": "com.example.mail",
    "name": "邮件助手",
    "version": "0.3.1",
    "author": "Community (example)",
    "type": "community",
    "category": "productivity",
    "description": "轮询邮件收件箱，将新邮件作为 RuntimeEvent 推送给订阅的 agent，实现邮件自动处理工作流。",
    "tags": ["email", "events", "productivity"],
    "repo": "https://github.com/example/modelflow-mail-plugin",
    "downloadUrl": "https://github.com/example/modelflow-mail-plugin/releases/download/v0.3.1/com.example.mail.zip",
    "permissions": [
      { "type": "network", "allowedHosts": ["imap.gmail.com", "smtp.gmail.com"] },
      { "type": "event_source" }
    ],
    "tools": [
      { "name": "list_emails", "description": "列出最近邮件" },
      { "name": "send_email", "description": "发送邮件" }
    ],
    "settings": [
      { "key": "imapHost", "label": "IMAP 服务器", "type": "string", "default": "imap.gmail.com" },
      { "key": "email", "label": "邮箱地址", "type": "string", "required": true },
      { "key": "password", "label": "密码", "type": "password", "required": true }
    ],
    "eventSources": [
      { "id": "inbox", "type": "poll", "tool": "list_emails", "topic": "email.received", "interval": 60 }
    ]
  },
  {
    "id": "com.example.imagegen",
    "name": "本地图像生成",
    "version": "0.2.0",
    "author": "Community (example)",
    "type": "community",
    "category": "media",
    "description": "通过本地 Stable Diffusion 服务生成图像，无需云端 API 即可让模型创作图片。",
    "tags": ["image", "stable-diffusion", "media", "local"],
    "repo": "https://github.com/example/modelflow-local-imagegen",
    "downloadUrl": "https://github.com/example/modelflow-local-imagegen/releases/download/v0.2.0/com.example.imagegen.zip",
    "permissions": [
      { "type": "network", "allowedHosts": ["127.0.0.1", "localhost"] }
    ],
    "tools": [
      { "name": "generate_image", "description": "根据提示词生成图像" }
    ],
    "settings": [
      { "key": "sdBaseUrl", "label": "Stable Diffusion 地址", "type": "string", "default": "http://127.0.0.1:7860" }
    ]
  },
  {
    "id": "com.example.clipboard",
    "name": "剪贴板工具",
    "version": "0.1.5",
    "author": "Community (example)",
    "type": "community",
    "category": "dev-tools",
    "description": "让模型读取与写入系统剪贴板，方便在 ModelFlow 与外部应用之间快速传递文本。",
    "tags": ["clipboard", "dev-tools"],
    "repo": "https://github.com/example/modelflow-clipboard",
    "downloadUrl": "https://github.com/example/modelflow-clipboard/releases/download/v0.1.5/com.example.clipboard.zip",
    "permissions": [
      { "type": "clipboard" }
    ],
    "tools": [
      { "name": "clipboard_read", "description": "读取剪贴板文本" },
      { "name": "clipboard_write", "description": "写入剪贴板文本" }
    ]
  }
]
